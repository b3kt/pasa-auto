{
  "name": "pazaauto-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build:frontend": "cd ../src/main/webui && npm run build",
    "copy:frontend": "rm -rf resources/ui && mkdir -p resources/ui && cp -r ../src/main/webui/dist/spa/* resources/ui/",
    "prebuild": "npm run build:frontend && npm run copy:frontend",
    "pack": "electron-builder --dir",
    "dist": "npm run prebuild && electron-builder",
    "dist:mac": "npm run prebuild && electron-builder --mac",
    "dist:win": "npm run prebuild && electron-builder --win",
    "dist:linux": "npm run prebuild && electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.github.b3kt.pazaauto",
    "productName": "PazaAuto",
    "files": [
      "main.js",
      "preload.js",
      "status-panel.html",
      "resources/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": ["dmg", "zip"],
      "icon": "resources/icon-green.png"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "resources/icon-green.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "resources/icon-green.png"
    }
  }
}
