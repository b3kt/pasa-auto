{
  "name": "pazaauto-electron",
  "version": "1.0.0",
  "description": "PazaAuto Desktop Application",
  "author": "B3KT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "node scripts/dev.js",
    "dev:simple": "NODE_ENV=development electron .",
    "dev:debug": "NODE_ENV=development electron --inspect=5858 .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:windows": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.github.b3kt.pazaauto",
    "productName": "PazaAutoApp",
    "files": [
      "main.js",
      "preload.js",
      "manager.html",
      "manager.js",
      "manager.css",
      "resources/**/*"
    ],
    "linux": {
      "icon": "resources/icon.png",
      "category": "Utility"
    },
    "win": {
      "icon": "resources/icon.png"
    },
    "mac": {
      "icon": "resources/icon.png"
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "."
      },
      {
        "from": "bin/pasa-auto-runner",
        "to": "pasa-auto-runner"
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
