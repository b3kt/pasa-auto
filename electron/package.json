{
  "name": "pazaauto-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:windows": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.github.b3kt.pazaauto",
    "productName": "PazaAutoApp",
    "files": [
      "main.js",
      "preload.js",
      "manager.html",
      "manager.js",
      "manager.css",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "."
      },
      {
        "from": "bin/pasa-auto-runner",
        "to": "pasa-auto-runner",
        "mode": "0755"
      }
    ],
    "directories": {
      "output": "dist"
    }
  }
}
