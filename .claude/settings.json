{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opusplan",
  "mcp": {
    "postgres": {
      "enabled": true,
      "host": "localhost",
      "port": 5432,
      "database": "pasaautodb",
      "user": "postgres",
      "password": "postgres"
    }
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(mvn *)",
      "Bash(java *)",
      "Read(./src/**)",
      "Read(./pom.xml)",
      "Edit(./src/**)",
      "Bash(psql *)",
      "Bash(pg *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  }
}