{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "../dist",
    "distDir": "../dist"
  },
  "package": {
    "productName": "PazaAuto",
    "version": "0.0.21"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "category": "Utility",
      "copyright": "Copyright (c) 2026 B3KT",
      "deb": {
        "depends": []
      },
      "externalBin": ["bin/pasa-auto-runner"],
      "icon": [],
      "identifier": "com.github.b3kt.pazaauto",
      "longDescription": "PazaAuto Desktop Application with backend management",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": ["resources/*"],
      "shortDescription": "PazaAuto Desktop App",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "trayIcon": {
      "iconPath": "resources/icon-red.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 650,
        "resizable": true,
        "title": "PazaAuto Manager",
        "width": 900,
        "minWidth": 700,
        "minHeight": 500,
        "center": true
      }
    ]
  }
}