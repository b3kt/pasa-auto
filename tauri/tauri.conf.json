{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PazaAuto",
  "version": "0.0.21",
  "identifier": "com.github.b3kt.pasaauto",
  "build": {
    "beforeBuildCommand": "echo 'no frontend build needed'",
    "beforeDevCommand": "echo 'no dev command needed'"
  },
  "app": {
    "windows": [
      {
        "title": "PazaAuto Manager",
        "width": 900,
        "height": 650,
        "minWidth": 700,
        "minHeight": 500,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/*"],
    "externalBin": ["bin/pasa-auto-runner"],
    "copyright": "Copyright (c) 2026 B3KT",
    "shortDescription": "PazaAuto Desktop App",
    "longDescription": "PazaAuto Desktop Application with backend management",
    "category": "Utility",
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}