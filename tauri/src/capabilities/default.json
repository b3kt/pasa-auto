{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/refs/heads/tauri-v2/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "PazaAuto default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
